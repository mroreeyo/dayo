// ─────────────────────────────────────────────────────────────
// Prisma Schema — Shared Calendar App (B안)
// Source of truth: 03-database.md, 05-api-spec.md, 08-recurrence.md
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────

enum MemberRole {
  OWNER
  ADMIN
  MEMBER

  @@map("member_role")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  JOIN
  LEAVE
  ROLE_CHANGE

  @@map("audit_action")
}

enum AuditEntityType {
  CALENDAR
  EVENT
  MEMBER
  INVITE

  @@map("audit_entity_type")
}

enum ExceptionAction {
  CANCEL
  OVERRIDE

  @@map("exception_action")
}

// ─── Models ─────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  nickname  String   @map("nickname") @db.VarChar(80)
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  calendarMembers CalendarMember[]
  createdEvents   Event[]          @relation("EventCreator")
  auditLogs       AuditLog[]
  deviceTokens    DeviceToken[]

  @@map("users")
}

model Calendar {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(80)
  color     String?  @db.VarChar(20)
  revision  BigInt   @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  members CalendarMember[]
  invites Invite[]
  events  Event[]

  @@map("calendars")
}

model CalendarMember {
  id         String     @id @default(uuid()) @db.Uuid
  calendarId String     @map("calendar_id") @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  role       MemberRole @default(MEMBER)
  revision   BigInt     @default(0)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([calendarId, userId])
  @@map("calendar_members")
}

model Invite {
  id         String    @id @default(uuid()) @db.Uuid
  calendarId String    @map("calendar_id") @db.Uuid
  code       String    @unique @db.VarChar(32)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz
  maxUses    Int?      @map("max_uses")
  useCount   Int       @default(0) @map("use_count")
  revision   BigInt    @default(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@map("invites")
}

model Event {
  id         String   @id @default(uuid()) @db.Uuid
  calendarId String   @map("calendar_id") @db.Uuid
  creatorId  String   @map("creator_id") @db.Uuid
  title      String   @db.VarChar(120)
  note       String?
  location   String?
  color      String?  @db.VarChar(20)
  timezone   String   @default("UTC")

  // ── Time fields ──
  allDay     Boolean  @default(false) @map("all_day")

  // Timed event fields (non-null when allDay=false)
  startAtUtc DateTime? @map("start_at_utc") @db.Timestamptz
  endAtUtc   DateTime? @map("end_at_utc") @db.Timestamptz

  // All-day event fields (non-null when allDay=true, endDate is exclusive)
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date

  // ── Reminder ──
  remindMinutes Int? @map("remind_minutes")

  // ── Optimistic lock + sync ──
  version  Int    @default(1)
  revision BigInt @default(0)

  // ── Soft delete ──
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  calendar       Calendar              @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  creator        User                  @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  recurrenceRule EventRecurrenceRule?
  exceptions     EventException[]

  @@map("events")
}

model EventRecurrenceRule {
  id          String    @id @default(uuid()) @db.Uuid
  eventId     String    @unique @map("event_id") @db.Uuid
  rrule       String    // e.g. "FREQ=WEEKLY;INTERVAL=1;BYDAY=MO,WE"
  dtstartUtc  DateTime? @map("dtstart_utc") @db.Timestamptz
  dtstartDate DateTime? @map("dtstart_date") @db.Date
  untilUtc    DateTime? @map("until_utc") @db.Timestamptz
  count       Int?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_recurrence_rules")
}

model EventException {
  id              String          @id @default(uuid()) @db.Uuid
  eventId         String          @map("event_id") @db.Uuid
  exceptionKey    String          @map("exception_key") // ISO datetime or YYYY-MM-DD
  action          ExceptionAction
  overridePayload Json?           @map("override_payload")
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, exceptionKey])
  @@map("event_exceptions")
}

model AuditLog {
  id         String          @id @default(uuid()) @db.Uuid
  calendarId String          @map("calendar_id") @db.Uuid
  userId     String          @map("user_id") @db.Uuid
  action     AuditAction
  entityType AuditEntityType @map("entity_type")
  entityId   String          @map("entity_id") @db.Uuid
  payload    Json?
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([calendarId, createdAt])
  @@map("audit_logs")
}

model DeviceToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  platform  String   @db.VarChar(10) // "ios" | "android"
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}
